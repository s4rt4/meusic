{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "meusic",
  "version": "0.1.0",
  "identifier": "com.sarta.meusic",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "meusic",
        "width": 1100,
        "height": 720,
        "minWidth": 880,
        "minHeight": 560,
        "theme": "Dark",
        "backgroundColor": "#0a0a0f"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
